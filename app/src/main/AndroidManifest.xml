<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DailyQuizMaster">
        <activity
            android:name=".activities.UploadQuestionsActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ProfileActivity"
            android:exported="false" /> <!-- Splash Screen -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- Authentication -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false" /> <!-- Home -->
        <activity
            android:name=".activities.HomeActivity"
            android:exported="false" /> <!-- Quiz -->
        <activity
            android:name=".activities.CategoryActivity"
            android:exported="false" />
        <activity
            android:name=".activities.QuizActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ResultActivity"
            android:exported="false" /> <!-- Leaderboard -->
        <activity
            android:name=".activities.LeaderboardActivity"
            android:exported="false" />
    </application>

</manifest>